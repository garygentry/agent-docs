# .github/workflows/docs.yml — GitHub Pages deploy (project Pages, subpath base)
# Generated by doc-site-plugin. Env-driven SITE/BASE_PATH (REQ-CORE-02/DEPLOY-02).
#
# This file ships TWO named toolchain fragments, selected by the agent per the
# detected {{RUNTIME}}/{{PKG_MANAGER}} (06 §3.3) — NOT by an in-YAML conditional:
#   * Bun + pnpm  -> the ACTIVE steps below (Setup Bun / Setup pnpm / pnpm ...).
#   * Node + npm  -> the COMMENTED "Node + npm fragment" block near the bottom;
#                    the agent swaps the Bun+pnpm steps for it when node/npm is
#                    detected.
# Only ONE fragment is emitted into the target repo. `${{ ... }}` sequences are
# GitHub Actions expressions, NOT generator tokens (generator tokens are
# double-brace UPPER_SNAKE names with no leading `$`).
name: docs

on:
  push:
    branches: ["{{DEFAULT_BRANCH}}"]
    paths:
      - "{{DOCS_PKG_DIR}}/**"
      - "docs/**"
      - "docs.manifest.json"
      - ".github/workflows/docs.yml"
  workflow_dispatch:

permissions:
  contents: read
  pages: write
  id-token: write

concurrency:
  group: pages
  cancel-in-progress: false

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      # --- Toolchain fragment: Bun + pnpm (active) ---
      - name: Setup Bun
        uses: oven-sh/setup-bun@v2

      - name: Setup pnpm
        uses: pnpm/action-setup@v4

      - name: Configure Pages
        id: pages
        uses: actions/configure-pages@v5

      - name: Install dependencies
        run: pnpm install --frozen-lockfile

      - name: Build docs site
        run: pnpm --filter ./{{DOCS_PKG_DIR}} build
        env:
          # Env-driven site/base — consumed by {{DOCS_PKG_DIR}}/astro.config.mjs
          # (03-core-site-and-manifest.md). Subpath base => assets resolve on
          # the project Pages subpath /<repo>/.
          SITE: ${{ steps.pages.outputs.origin }}
          BASE_PATH: ${{ steps.pages.outputs.base_path }}
          # Literal-base fallback (rare — custom domain served at root): for the
          # project site https://github.com/{{REPO_SLUG}} the agent may replace the
          # two runtime-derived lines above with literal interview values instead:
          #   SITE: {{SITE_URL}}
          #   BASE_PATH: {{BASE_PATH}}
      # --- end Bun + pnpm fragment ---

      - name: Upload Pages artifact
        uses: actions/upload-pages-artifact@v3
        with:
          path: "{{DOCS_PKG_DIR}}/dist"

  deploy:
    needs: build
    runs-on: ubuntu-latest
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    steps:
      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v4

# === Toolchain fragment: Node + npm (alternative — 06 §3.5) =================
# When {{RUNTIME}}=node / {{PKG_MANAGER}}=npm is detected, the agent replaces the
# "Bun + pnpm (active)" steps above with the following. Monorepo uses
# `--workspace`; a single-package target uses `working-directory` instead.
#
#       - name: Setup Node
#         uses: actions/setup-node@v4
#         with:
#           node-version: lts/*
#           cache: npm
#
#       - name: Configure Pages
#         id: pages
#         uses: actions/configure-pages@v5
#
#       - name: Install dependencies
#         run: npm ci
#
#       # Monorepo (workspaces) build invocation:
#       - name: Build docs site
#         run: npm run build --workspace {{DOCS_PKG_DIR}}
#         env:
#           SITE: ${{ steps.pages.outputs.origin }}
#           BASE_PATH: ${{ steps.pages.outputs.base_path }}
#
#       # Single-package build invocation (use INSTEAD of the workspace step):
#       - name: Build docs site
#         run: npm run build
#         working-directory: {{DOCS_PKG_DIR}}
#         env:
#           SITE: ${{ steps.pages.outputs.origin }}
#           BASE_PATH: ${{ steps.pages.outputs.base_path }}
# ===========================================================================
