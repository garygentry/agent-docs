# .github/workflows/docs.yml — GitHub Pages deploy (project Pages, subpath base)
# Generated by doc-site. Env-driven SITE/BASE_PATH (REQ-CORE-02/DEPLOY-02).
#
# The toolchain steps are emitted from the detected runtime and package manager
# via DERIVED tokens (06 §3) — not by an in-YAML conditional. These comment lines
# are intentionally LITERAL (no tokens) so substitution can't mangle them:
#   * the runtime setup action (setup-node vs setup-bun) at the `uses:` below.
#   * the package-manager setup step is injected at the `# <<PKG_SETUP>>` sentinel
#     (pnpm needs pnpm/action-setup; npm/yarn/bun need none).
#   * the frozen-lockfile install command for the detected package manager.
#   * the workspace/filter build invocation.
# The drift-guard step is injected at the `# <<DRIFT_STEP>>` sentinel only when
# driftGuard + this deploy target are both selected (drift-guard.md §4). The
# `# <<PATH_FILTERS>>` sentinel is replaced by the deduplicated docs path filters.
#
# `${{ ... }}` sequences are GitHub Actions expressions, NOT generator tokens
# (generator tokens are double-brace UPPER_SNAKE names with no leading `$`).
name: docs

on:
  push:
    branches: ["{{DEFAULT_BRANCH}}"]
    paths:
      # <<PATH_FILTERS>> — deduplicated docs path filters ({{DOCS_PKG_DIR}}/**, docs/**, manifest).
      - "{{DOCS_PKG_DIR}}/**"
      - "docs/**"
      - "{{DOCS_PKG_DIR}}/docs.manifest.json"
      - ".github/workflows/docs.yml"
  workflow_dispatch:

permissions:
  contents: read
  pages: write
  id-token: write

concurrency:
  group: pages
  cancel-in-progress: false

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Setup runtime
        uses: {{CI_SETUP_ACTION}}
      # <<PKG_SETUP>> — package-manager setup step (pnpm/action-setup) when needed.

      - name: Configure Pages
        id: pages
        uses: actions/configure-pages@v5

      - name: Install dependencies
        run: {{INSTALL_CMD}}

      - name: Build docs site
        run: {{WORKSPACE_BUILD}}
        env:
          # Env-driven site/base — consumed by the docs package astro.config.mjs
          # (03-core-site-and-manifest.md). Subpath base => assets resolve on the
          # project Pages subpath /<repo>/.
          SITE: ${{ steps.pages.outputs.origin }}
          BASE_PATH: ${{ steps.pages.outputs.base_path }}
          # Literal-base fallback (rare — custom domain served at root): for the
          # project site https://github.com/{{REPO_SLUG}} the agent may replace the
          # two runtime-derived lines above with literal interview values instead:
          #   SITE: {{SITE_URL}}
          #   BASE_PATH: {{BASE_PATH}}

      # <<DRIFT_STEP>> — drift-guard step injected when driftGuard + github-pages.

      - name: Upload Pages artifact
        uses: actions/upload-pages-artifact@v3
        with:
          path: "{{DOCS_PKG_DIR}}/dist"

  deploy:
    needs: build
    runs-on: ubuntu-latest
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    steps:
      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v4
