# netlify.toml — generated by doc-site.
# Env-driven SITE/BASE_PATH (REQ-CORE-02/DEPLOY-02); root-hosted by default.
# `command` shows the pnpm form; the agent swaps it to the detected package
# manager's build command (06 §5.3). With `base` set, the build runs
# package-local, so no --filter/--workspace is needed regardless of monorepo
# vs single.

[build]
  base = "{{DOCS_PKG_DIR}}"
  command = "pnpm build"
  publish = "dist"

[build.environment]
  SITE = "{{SITE_URL}}"
  BASE_PATH = "{{BASE_PATH}}"
