{
  "type": "object",
  "properties": {
    "diagramType": {
      "type": "string",
      "enum": [
        "architecture",
        "flowchart",
        "sequence",
        "er",
        "state",
        "dataflow"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "theme": {
      "type": "string",
      "enum": [
        "light",
        "dark"
      ],
      "default": "light"
    },
    "accent": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$"
    },
    "background": {
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "transparent",
            "opaque"
          ]
        },
        {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        }
      ]
    },
    "direction": {
      "type": "string",
      "enum": [
        "LR",
        "TB",
        "RL",
        "BT"
      ]
    },
    "fill": {
      "type": "string",
      "enum": [
        "translucent",
        "solid",
        "transparent"
      ]
    },
    "cardStyle": {
      "type": "string",
      "enum": [
        "elevated",
        "flat"
      ]
    },
    "legend": {
      "type": "string",
      "enum": [
        "auto",
        "right",
        "bottom",
        "none"
      ]
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "enum": [
              "default",
              "frontend",
              "backend",
              "database",
              "queue",
              "cache",
              "external",
              "security",
              "gateway",
              "storage",
              "compute"
            ]
          },
          "shape": {
            "type": "string",
            "enum": [
              "box",
              "rounded",
              "cylinder",
              "diamond",
              "ellipse"
            ]
          }
        },
        "required": [
          "id",
          "label"
        ],
        "additionalProperties": false
      },
      "default": []
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "to": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "label": {
            "type": "string"
          },
          "direction": {
            "type": "string",
            "enum": [
              "forward",
              "back",
              "both",
              "none"
            ]
          },
          "style": {
            "type": "string",
            "enum": [
              "solid",
              "dashed",
              "dotted",
              "bold"
            ]
          }
        },
        "required": [
          "from",
          "to"
        ],
        "additionalProperties": false
      },
      "default": []
    },
    "containers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "children": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9_-]+$"
            },
            "default": []
          },
          "parent": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_-]+$"
          }
        },
        "required": [
          "id",
          "label"
        ],
        "additionalProperties": false
      },
      "default": []
    },
    "participants": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "enum": [
              "default",
              "frontend",
              "backend",
              "database",
              "queue",
              "cache",
              "external",
              "security",
              "gateway",
              "storage",
              "compute"
            ]
          }
        },
        "required": [
          "id",
          "label"
        ],
        "additionalProperties": false
      },
      "default": []
    },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "to": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "sync",
              "async",
              "reply"
            ],
            "default": "sync"
          },
          "activate": {
            "type": "boolean"
          }
        },
        "required": [
          "from",
          "to",
          "label"
        ],
        "additionalProperties": false
      },
      "default": []
    }
  },
  "required": [
    "diagramType",
    "title",
    "description"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "diagram-input.schema.json",
  "title": "Diagram Generator Input Spec",
  "description": "Engine-neutral DiagramSpec for the diagram-generator skill (REQ-IN-02). Per-field shape only; cross-field referential/type-agreement invariants are enforced at runtime (02-schema-and-validation.md §2), not in this schema."
}
