{
  "tokens": {
    "SITE_TITLE": "Acme Docs",
    "SITE_TITLE_SLUG": "acme-docs",
    "SITE_DESC": "Documentation for the Acme project.",
    "SITE_URL": "https://acme.github.io",
    "BASE_PATH": "/acme",
    "REPO_SLUG": "acme-org/acme",
    "GITHUB_URL": "https://github.com/acme-org/acme",
    "PKG_MANAGER": "pnpm",
    "RUNTIME": "node",
    "DOCS_PKG_DIR": "docs",
    "IMAGES_SRC_DIR": "docs/images",
    "ACCENT_LIGHT": "#2563eb",
    "ACCENT_DARK": "#60a5fa",
    "DEFAULT_BRANCH": "main",
    "ASTRO_VERSION": "5.6.1",
    "STARLIGHT_VERSION": "0.32.2",
    "REHYPE_LINKS_VERSION": "1.0.15",
    "DOCS_PKG_DIR_TO_ROOT": ".."
  },
  "selection": {
    "contentMode": "symlink",
    "diagrams": false,
    "deploy": ["github-pages"],
    "driftGuard": true,
    "monorepo": false
  },
  "site": {
    "title": "Acme Docs",
    "description": "Documentation for the Acme project.",
    "social": { "github": "https://github.com/acme-org/acme" }
  },
  "pages": [
    { "slug": "getting-started", "source": "symlink", "from": "docs/getting-started.md" },
    { "slug": "guides/usage", "source": "symlink", "from": "docs/guides/usage.md" }
  ]
}
